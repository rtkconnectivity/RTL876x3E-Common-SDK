config SOC_RTL8763EW_VP
    bool "RTL8763EW-VP"

config SOC_RTL8763EWE
    bool "RTL8763EWE"

config SOC_RTL8763EWE_VP
    bool "RTL8763EWE-VP"
endchoice


config REALTEK_TARGET_RTL8763EAU
