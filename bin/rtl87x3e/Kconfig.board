    int
    default 1 if SOC_RTL8763EFL
    default 0
    help
      TARGET_RTL8763EFL

config REALTEK_TARGET_RTL8763ESL
    int
    default 1 if SOC_RTL8763ESL
    default 0
    help
      TARGET_RTL8763ESL

config REALTEK_TARGET_RTL8763EHA
    int
    default 1 if SOC_RTL8763EHA
    default 0
