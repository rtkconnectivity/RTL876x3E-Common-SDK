      TARGET_RTL8763EHA

config REALTEK_TARGET_RTL8763EF
    int
    default 1 if SOC_RTL8763EF
    default 0
    help
      TARGET_RTL8763EF

config REALTEK_TARGET_RTL8763EW
    int
    default 1 if SOC_RTL8763EW
    default 0
